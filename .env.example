SEPSIS_ENVIRONMENT=development
SEPSIS_LOG_LEVEL=INFO
SEPSIS_JSON_LOGS=true
SEPSIS_API_HOST=127.0.0.1
SEPSIS_API_PORT=8000
SEPSIS_MODEL_ARTIFACT_PATH=artifacts/models/model.pkl
SEPSIS_SELECTED_SEQUENCE_MANIFEST_PATH=artifacts/models/registry/selected_model.json
SEPSIS_SERVING_DEFAULT_OPERATING_MODE=default
SEPSIS_ENABLE_MLFLOW=false
SEPSIS_MLFLOW_TRACKING_URI=sqlite:///mlflow.db
SEPSIS_MLFLOW_EXPERIMENT_NAME=early-sepsis-local
SEPSIS_ENABLE_PREFECT=false
SEPSIS_ENABLE_LOCAL_LLM=false
SEPSIS_LOCAL_LLM_ENDPOINT=http://127.0.0.1:11434/api/generate
SEPSIS_LOCAL_LLM_MODEL=mistral
SEPSIS_LOCAL_LLM_TIMEOUT_SECONDS=20
SEPSIS_DEFAULT_TARGET_COLUMN=SepsisLabel
SEPSIS_RANDOM_SEED=42
SEPSIS_RAW_DATA_DIR=data/raw
SEPSIS_LOCAL_CSV_DATA_DIR=data/local_csv
SEPSIS_PROCESSED_DATA_DIR=artifacts/processed
SEPSIS_WINDOW_DATA_DIR=artifacts/windows
SEPSIS_SPLIT_MANIFEST_DIR=artifacts/processed/split_manifests
SEPSIS_TRAIN_RATIO=0.7
SEPSIS_VALIDATION_RATIO=0.15
SEPSIS_TEST_RATIO=0.15
SEPSIS_WINDOW_LENGTH=8
SEPSIS_PREDICTION_HORIZON=6
SEPSIS_ENABLE_PADDING_WINDOWS=false
